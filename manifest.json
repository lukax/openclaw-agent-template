{
  "$schema": "https://agents.pinata.cloud/schemas/manifest.v1.json",
  "version": 1,
  "agent": {
    "name": "Frontend Dev",
    "description": "An AI agent specialized in frontend development with Vite, React, and TypeScript. Ships clean, accessible UIs from a pre-configured scaffold.",
    "vibe": "clean code, great UX, ships fast",
    "emoji": "⚛️"
  },
  "template": {
    "slug": "frontend-dev-agent",
    "category": "general",
    "tags": ["frontend", "react", "vite", "typescript"],
    "partnerName": "Pinata",
    "partnerLogoUrl": "https://agents.pinata.cloud/logo.png"
  },
  "secrets": [
    {
      "name": "ANTHROPIC_API_KEY",
      "description": "Anthropic API key for Claude access",
      "required": true
    }
  ],
  "skills": [
     {
       "cid": "alchemy-official",
       "clawhub_slug": "alchemy-official",
       "name": "Alchemy Official"
     }
  ],
  "scripts": {
    "build": "cd workspace/projects/starter && npm install --include=dev",
    "start": "cd workspace/projects/starter && npx vite --host 0.0.0.0"
  },
  "routes": [
    {
      "port": 5173,
      "path": "/app",
      "protected": false
    }
  ]
}
